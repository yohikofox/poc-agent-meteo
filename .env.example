# Copier ce fichier en .env pour docker compose

# URL Ollama sur le poste hôte
# Mac local     : http://host.docker.internal:11434  (valeur par défaut)
# Portainer/Linux : http://host.docker.internal:11434  (host-gateway résout automatiquement)
# Ollama distant : http://192.168.1.x:11434
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b
